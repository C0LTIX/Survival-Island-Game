<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Instant Render Survival</title></head>
<body style="margin:0;overflow:hidden;">
<script src="https://cdn.jsdelivr.net/npm/three@0.152/build/three.min.js"></script>
<script>
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x87ceeb);
const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
camera.position.set(0,20,30);
camera.lookAt(0,0,0);

const renderer = new THREE.WebGLRenderer();
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.shadowMap.enabled = true;
document.body.appendChild(renderer.domElement);

// LIGHT
const ambient = new THREE.AmbientLight(0xffffff, 0.7);
scene.add(ambient);
const sun = new THREE.DirectionalLight(0xffffff, 1);
sun.position.set(50,100,50);
scene.add(sun);

// TERRAIN
const terrain = new THREE.Mesh(new THREE.PlaneGeometry(200,200,20,20), new THREE.MeshStandardMaterial({color:0x3d8f2d}));
terrain.rotation.x = -Math.PI/2;
terrain.receiveShadow = true;
scene.add(terrain);

// PLAYER
const player = new THREE.Mesh(new THREE.BoxGeometry(2,3,2), new THREE.MeshStandardMaterial({color:0x00ffff}));
player.position.set(0,1.5,0);
scene.add(player);

// TREES
for(let i=0;i<10;i++){
  const tree = new THREE.Mesh(new THREE.CylinderGeometry(0.5,0.7,10), new THREE.MeshStandardMaterial({color:0x8b5a2b}));
  tree.position.set(Math.random()*50-25,5,Math.random()*50-25);
  scene.add(tree);
  const leaf = new THREE.Mesh(new THREE.SphereGeometry(3), new THREE.MeshStandardMaterial({color:0x1f7a1f}));
  leaf.position.set(tree.position.x,10,tree.position.z);
  scene.add(leaf);
}

// SIMPLE ANIMAL
const pig = new THREE.Mesh(new THREE.BoxGeometry(1,0.5,0.5), new THREE.MeshStandardMaterial({color:0xffb6b6}));
pig.position.set(5,0.25,5);
scene.add(pig);

// WATER
const water = new THREE.Mesh(new THREE.PlaneGeometry(200,200), new THREE.MeshStandardMaterial({color:0x1e90ff,transparent:true,opacity:0.5}));
water.rotation.x = -Math.PI/2;
water.position.y = -1;
scene.add(water);

// RENDER LOOP
function animate(){
  requestAnimationFrame(animate);
  renderer.render(scene,camera);
}
animate();
</script>
</body>
</html>
