<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Survival Island Full Settings & Cooking</title>
<style>
body{margin:0;overflow:hidden;font-family:Arial;}
#hud{
  position:absolute;top:10px;left:10px;color:white;background:rgba(0,0,0,0.5);padding:10px;z-index:1;
}
#settings{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  background:rgba(0,0,0,0.8);color:white;padding:20px;display:none;z-index:2;
}
button{margin:5px;}
</style>
</head>
<body>
<div id="hud">
Hunger: <span id="hunger">100</span>% | Health: <span id="health">100</span>% | Wood: <span id="wood">0</span> | Food: <span id="food">0</span>
</div>

<div id="settings">
<h3>Settings</h3>
<label>Shadows: <input type="checkbox" id="shadows" checked></label><br>
<label>Terrain Quality: <select id="terrainQuality"><option>Low</option><option selected>High</option></select></label><br>
<button id="closeSettings">Close</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/three@0.152/build/three.min.js"></script>
<script>

// --- SCENE, CAMERA, RENDERER ---
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x87ceeb);
const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
camera.position.set(0,10,20); camera.lookAt(0,0,0);
const renderer = new THREE.WebGLRenderer({antialias:true});
renderer.setSize(window.innerWidth,window.innerHeight);
renderer.shadowMap.enabled=true; document.body.appendChild(renderer.domElement);

// --- LIGHT ---
const ambient = new THREE.AmbientLight(0xffffff,0.8); scene.add(ambient);
const sun = new THREE.DirectionalLight(0xffffff,0.6); sun.position.set(10,20,10); scene.add(sun);

// --- TERRAIN & WATER ---
const terrain = new THREE.Mesh(new THREE.PlaneGeometry(200,200,50,50), new THREE.MeshStandardMaterial({color:0x3d8f2d}));
terrain.rotation.x=-Math.PI/2; terrain.receiveShadow=true; scene.add(terrain);
const water = new THREE.Mesh(new THREE.PlaneGeometry(200,200), new THREE.MeshStandardMaterial({color:0x1e90ff,transparent:true,opacity:0.5}));
water.rotation.x=-Math.PI/2; water.position.y=-1; scene.add(water);

// --- TREES & FRUITS ---
const fruits=[];
for(let i=0;i<15;i++){
  const trunk=new THREE.Mesh(new THREE.CylinderGeometry(0.5,0.7,10), new THREE.MeshStandardMaterial({color:0x8b5a2b}));
  trunk.position.set(Math.random()*50-25,5,Math.random()*50-25); scene.add(trunk);
  const leaf=new THREE.Mesh(new THREE.SphereGeometry(3), new THREE.MeshStandardMaterial({color:0x1f7a1f}));
  leaf.position.set(trunk.position.x,10,trunk.position.z); scene.add(leaf);
  const f=new THREE.Mesh(new THREE.SphereGeometry(0.5), new THREE.MeshStandardMaterial({color:0xff00ff}));
  f.position.set(trunk.position.x,8,trunk.position.z); scene.add(f); fruits.push(f);
}

// --- ANIMALS ---
const pigs=[], sharks=[];
for(let i=0;i<5;i++){const pig=new THREE.Mesh(new THREE.BoxGeometry(1,0.5,0.5), new THREE.MeshStandardMaterial({color:0xffb6b6}));
pig.position.set(Math.random()*50-25,0.25,Math.random()*50-25); scene.add(pig); pigs.push(pig);}
for(let i=0;i<2;i++){const s=new THREE.Mesh(new THREE.BoxGeometry(3,1,1), new THREE.MeshStandardMaterial({color:0x4444ff}));
s.position.set(Math.random()*50-25,-0.5,Math.random()*50-25); scene.add(s); sharks.push(s);}

// --- PLAYER ---
const player=new THREE.Group();
const body=new THREE.Mesh(new THREE.BoxGeometry(1,2,0.5),new THREE.MeshStandardMaterial({color:0x00ffff})); body.position.y=1; player.add(body);
const head=new THREE.Mesh(new THREE.BoxGeometry(0.6,0.6,0.6),new THREE.MeshStandardMaterial({color:0xffffaa})); head.position.y=2.3; player.add(head);
const leftArm=new THREE.Mesh(new THREE.BoxGeometry(0.3,1.5,0.3),new THREE.MeshStandardMaterial({color:0x00ffff})); leftArm.position.set(-0.8,1.25,0); player.add(leftArm);
const rightArm=new THREE.Mesh(new THREE.BoxGeometry(0.3,1.5,0.3),new THREE.MeshStandardMaterial({color:0x00ffff})); rightArm.position.set(0.8,1.25,0); player.add(rightArm);
const leftLeg=new THREE.Mesh(new THREE.BoxGeometry(0.4,1.5,0.4),new THREE.MeshStandardMaterial({color:0x00ffff})); leftLeg.position.set(-0.3,-0.75,0); player.add(leftLeg);
const rightLeg=new THREE.Mesh(new THREE.BoxGeometry(0.4,1.5,0.4),new THREE.MeshStandardMaterial({color:0x00ffff})); rightLeg.position.set(0.3,-0.75,0); player.add(rightLeg);
player.position.set(0,0,0); scene.add(player);

// --- CAMPFIRES ---
const campfires=[];
for(let i=0;i<3;i++){
  const base=new THREE.Mesh(new THREE.CylinderGeometry(0.5,0.5,0.2), new THREE.MeshStandardMaterial({color:0x8b4513}));
  base.position.set(Math.random()*50-25,0.1,Math.random()*50-25); scene.add(base);
  const fire=new THREE.Mesh(new THREE.ConeGeometry(0.5,1,6), new THREE.MeshStandardMaterial({color:0xff4500,emissive:0xff4500})); fire.position.set(base.position.x,0.7,base.position.z); scene.add(fire);
  campfires.push({base,fire});
}

// --- CAMERA FOLLOW ---
let yaw=new THREE.Object3D(); let pitch=new THREE.Object3D(); yaw.position.y=10; yaw.add(pitch); scene.add(yaw); pitch.add(camera);

// --- MOUSE LOOK ---
const sensitivity=0.002, pitchLimit=Math.PI/3;
document.body.addEventListener('click',()=>{document.body.requestPointerLock()});
document.addEventListener('pointerlockchange',()=>{if(document.pointerLockElement===document.body) document.addEventListener('mousemove',onMouseMove,false); else document.removeEventListener('mousemove',onMouseMove,false)});
function onMouseMove(e){yaw.rotation.y-=e.movementX*sensitivity; pitch.rotation.x-=e.movementY*sensitivity; pitch.rotation.x=Math.max(-pitchLimit,Math.min(pitchLimit,pitch.rotation.x))}

// --- MOVEMENT ---
const keys={}; document.addEventListener('keydown',e=>{keys[e.key.toLowerCase()]=true}); document.addEventListener('keyup',e=>{keys[e.key.toLowerCase()]=false});

// --- SURVIVAL STATS ---
let hunger=100, health=100, wood=0, foodCount=0;
const hungerEl=document.getElementById("hunger"), healthEl=document.getElementById("health");
function updateStats(){hungerEl.innerText=Math.floor(hunger); healthEl.innerText=Math.floor(health);}

// --- ANIMAL AI ---
function updateAnimals(){
  for(let p of pigs){ const dir=new THREE.Vector3(Math.random()-0.5,0,Math.random()-0.5); p.position.add(dir.multiplyScalar(0.1));}
  for(let s of sharks){
    if(player.position.y<0){ const dir=new THREE.Vector3().subVectors(player.position,s.position).normalize().multiplyScalar(0.08); s.position.add(dir); if(s.position.distanceTo(player.position)<3) health-=0.5;} 
    else{ s.position.add(new THREE.Vector3(Math.random()-0.5,0,Math.random()-0.5).multiplyScalar(0.05));}
  }
}

// --- DAY/NIGHT ---
let dayTime=0;
function updateDayNight(){
  dayTime+=0.001;
  sun.position.set(Math.sin(dayTime*2*Math.PI)*50,Math.cos(dayTime*2*Math.PI)*50,10);
  scene.background = new THREE.Color().setHSL(0.6,0.7,Math.max(0.2,0.5*Math.cos(dayTime*2*Math.PI)+0.5));
}

// --- FRUIT COLLECTION & COOKING ---
function checkFruitAndCampfire(){
  // Fruits
  for(let i=fruits.length-1;i>=0;i--){
    if(player.position.distanceTo(fruits[i].position)<1){ foodCount++; scene.remove(fruits[i]); fruits.splice(i,1);}
  }
  // Cooking at campfires
  for(let c of campfires){
    if(player.position.distanceTo(c.base.position)<2 && wood>0 && foodCount>0){
      // Cook one food -> restores hunger
      hunger=Math.min(100,hunger+20); wood--; foodCount--;
    }
  }
}

// --- SETTINGS MENU ---
const settings=document.getElementById("settings");
document.addEventListener("keydown",e=>{if(e.key==="Escape"){settings.style.display=settings.style.display==="none"?"block":"none";}});
document.getElementById("closeSettings").onclick=()=>{settings.style.display="none";};

// --- ANIMATE LOOP ---
function animate(){
  requestAnimationFrame(animate);
  yaw.position.copy(player.position); yaw.position.y=10;

  // Movement
  let speed=0.3;
  let forward=new THREE.Vector3(0,0,-1).applyQuaternion(yaw.quaternion);
  let right=new THREE.Vector3(1,0,0).applyQuaternion(yaw.quaternion);
  let dir=new THREE.Vector3();
  if(keys["w"]) dir.add(forward);
  if(keys["s"]) dir.sub(forward);
  if(keys["a"]) dir.sub(right);
  if(keys["d"]) dir.add(right);
  if(dir.length()>0) player.position.addScaledVector(dir.normalize(),speed);

  // Hunger
  hunger-=0.002; if(hunger<=0){health-=0.05; hunger=0;} if(health<0) health=0;

  // Animals, Fruit & Cooking
  updateAnimals(); checkFruitAndCampfire(); updateDayNight(); updateStats();
  renderer.render(scene,camera);
}
animate();

// --- RESIZE ---
window.addEventListener('resize',()=>{camera.aspect=window.innerWidth/window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth,window.innerHeight)});

</script>
</body>
</html>
